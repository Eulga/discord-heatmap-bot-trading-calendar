# Core Discord/app settings
# - `DISCORD_BOT_TOKEN` is required at startup.
# - `DEFAULT_FORUM_CHANNEL_ID` is an optional fallback forum channel ID.
# - `DISCORD_GLOBAL_ADMIN_USER_IDS` is a comma-separated list of Discord user IDs.
DISCORD_BOT_TOKEN=your_bot_token_here
DEFAULT_FORUM_CHANNEL_ID=
DISCORD_GLOBAL_ADMIN_USER_IDS=

# Logging
# - `LOG_FILE_PATH` accepts a relative or absolute filesystem path.
# - `LOG_RETENTION_DAYS` is an integer day count.
# - Toggle values use `true` or `false`.
LOG_FILE_PATH=data/logs/bot.log
LOG_RETENTION_DAYS=7
# options: true | false
LOG_CONSOLE_ENABLED=true

# News briefing and market provider selection
# - Time values use `HH:MM` in KST.
# - Query list values are comma-separated.
# - API timeout is integer seconds, retry count is integer retries.
# - Leave API keys/tokens empty unless the matching provider is enabled.
# - `DART_API_KEY` is only needed for registry expansion scripts.
# - Use `MASSIVE_API_KEY` for Massive (formerly Polygon.io). `POLYGON_API_KEY` is still accepted as a legacy fallback in code.
# options: true | false
NEWS_BRIEFING_ENABLED=true
NEWS_BRIEFING_TIME=07:30
# options: true | false
NEWS_BRIEFING_TRADING_DAYS_ONLY=false
# options: mock | naver | marketaux | hybrid
NEWS_PROVIDER_KIND=mock
# options: mock | kis
MARKET_DATA_PROVIDER_KIND=mock
DART_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
MARKETAUX_API_TOKEN=
MASSIVE_API_KEY=
TWELVEDATA_API_KEY=
OPENFIGI_API_KEY=
NAVER_NEWS_CLIENT_ID=
NAVER_NEWS_CLIENT_SECRET=
NAVER_NEWS_DOMESTIC_QUERY=국내 증시
NAVER_NEWS_GLOBAL_QUERY=미국 증시
NAVER_NEWS_DOMESTIC_QUERIES=국내 증시,코스피 지수,코스닥 지수,원달러 환율,한국은행 금리
NAVER_NEWS_GLOBAL_QUERIES=미국 증시,나스닥,S&P 500,연준,FOMC
NAVER_NEWS_DOMESTIC_STOCK_QUERIES=삼성전자,SK하이닉스,현대차,한화에어로스페이스,셀트리온
NAVER_NEWS_GLOBAL_STOCK_QUERIES=엔비디아,애플,마이크로소프트,테슬라,마이크론
MARKETAUX_NEWS_GLOBAL_QUERY=Nasdaq OR S&P 500 OR Federal Reserve OR FOMC OR Treasury yields
MARKETAUX_NEWS_GLOBAL_QUERIES=Nasdaq OR S&P 500 OR Federal Reserve OR FOMC OR Treasury yields,US stocks OR Nasdaq,Federal Reserve OR FOMC,Treasury yields OR CPI OR PCE
MARKETAUX_NEWS_COUNTRIES=us
MARKETAUX_NEWS_LANGUAGE=en
NAVER_NEWS_LIMIT_PER_REGION=20
NAVER_NEWS_MAX_AGE_HOURS=24
INTEL_API_TIMEOUT_SECONDS=5
INTEL_API_RETRY_COUNT=1

# EOD summary and watch polling
# - Time values use `HH:MM` in KST.
# - Poll interval is integer seconds.
# - Threshold is a float percentage.
# - Cooldown is integer minutes.
# options: true | false
EOD_SUMMARY_ENABLED=false
EOD_SUMMARY_TIME=16:20
# options: true | false
WATCH_POLL_ENABLED=true
WATCH_POLL_INTERVAL_SECONDS=60
WATCH_ALERT_THRESHOLD_PCT=3.0
WATCH_ALERT_COOLDOWN_MINUTES=10

# Discord targets
# - `ADMIN_STATUS_CHANNEL_ID` is a text channel ID.
# - `NEWS_TARGET_FORUM_ID` and `EOD_TARGET_FORUM_ID` are forum channel IDs.
# - `WATCH_ALERT_CHANNEL_ID` must be a regular text/messageable channel ID, not a forum channel.
ADMIN_STATUS_CHANNEL_ID=
NEWS_TARGET_FORUM_ID=
EOD_TARGET_FORUM_ID=
WATCH_ALERT_CHANNEL_ID=
